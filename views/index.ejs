<!DOCTYPE html>
<html lang="zh-HK">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>一番賞線上抽獎 - Ichiban Kuji Raffle</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <header>
    <div class="container">
      <div class="header-content">
        <div class="header-text">
          <h1>一番賞線上抽獎</h1>
          <p>公平公開，即抽即中</p>
        </div>
        <div class="header-buttons">
          <% if (currentUser) { %>
            <a href="/my" class="btn btn-secondary btn-sm">我的記錄</a>
            <a href="/logout" class="btn btn-secondary btn-sm">登出</a>
          <% } else { %>
            <a href="/login" class="btn btn-secondary btn-sm">會員登入</a>
          <% } %>
          <% if (isAdmin) { %>
            <a href="/admin" class="btn btn-secondary btn-sm">管理後台</a>
          <% } else { %>
            <a href="/admin/login" class="btn btn-secondary btn-sm">管理員登入</a>
          <% } %>
        </div>
      </div>
    </div>
  </header>

  <main class="container">
    <h2>進行中的抽獎活動</h2>
    
    <% if (raffles.length === 0) { %>
      <div class="empty-state">
        <p>目前沒有進行中的抽獎活動</p>
      </div>
    <% } else { %>
      <div class="raffle-list">
        <% raffles.forEach(raffle => { %>
          <div class="raffle-card">
            <h3><%= raffle.title %></h3>
            <p><%= raffle.description %></p>
            <div class="raffle-stats">
              <span class="stat">
                <strong>價格</strong>: HK$<%= raffle.price_per_box %>
              </span>
              <span class="stat">
                <strong>剩餘</strong>: <%= raffle.remaining_boxes %> / <%= raffle.total_boxes %>
              </span>
            </div>
            <a href="/raffle/<%= raffle.id %>" class="btn btn-primary">立即抽獎</a>
          </div>
        <% }) %>
      </div>
    <% } %>
  </main>

  <footer>
    <div class="container">
      <p>&copy; <%= new Date().getFullYear() %> Ichiban Kuji Raffle System</p>
      <p style="margin-top: 8px; opacity: 0.7;">
        <a href="https://github.com/clawdfelix-ship-it/ichiban-kuji-raffle" target="_blank" style="color: inherit;">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" style="display: inline-block; vertical-align: middle; margin-right: 4px;">
            <path fill-rule="evenodd" d="M8 0C3.58 0 0 0 3.5 3.5 8 8 8 8 8zm-6 8v-6a.75.75 0 0 1 0v5a.75.75 0 0 0 0 5 1h6c0 6zM0 2.6c.79.79 1.48 1.58 3.5 3.5 6.32 6.44 5.68 7.03 6.91c.46-.45 1.08-.95 1.53-1.6 1.53C1.8 2.1 2.65 2.65 3.5 2.4c.31-.3.68-.64.72-.92 1.1-.66 1.4-1.19 1.15C4.2 1.36 4.8 1.15 5.34 1.06 6.04.91 6.39.5 7.1.88 6.9 4.8 8 1.3 8 0 1z"/>
          </svg>
          Powered by Ichiban Kuji Raffle
        </a>
      </p>
    </div>
  </footer>
</body>
</html>
