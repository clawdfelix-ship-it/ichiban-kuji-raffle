<!DOCTYPE html>
<html lang="zh-HK">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="color-scheme" content="light dark">
  <meta name="description" content="本平台提供台灣一番賞代購、代抽、代收與跨境轉送服務，所有抽選行為於台灣完成，香港地區僅提供商品領取與寄送。">
  <title><%= (typeof adminMode !== 'undefined' && adminMode) ? '管理員登入' : '會員登入' %> - 台灣一番賞委託代抽</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <header>
    <div class="container">
      <a href="/" class="site-logo">
        <img src="/img/mirai-3.png" alt="TMA台灣分部-未來飛翔">
      </a>
      <a href="/" class="back-link">← 返回首頁</a>
      <h1><%= (typeof adminMode !== 'undefined' && adminMode) ? '管理員登入' : '會員登入' %></h1>
    </div>
  </header>

  <main class="container">
    <div class="auth-form">
      <form id="loginForm">
        <input type="hidden" id="adminModeFlag" value="<%= (typeof adminMode !== 'undefined' && adminMode) ? '1' : '0' %>">
        <div class="form-group">
          <label for="username">用戶名</label>
          <input type="text" id="username" name="username" required placeholder="輸入用戶名">
        </div>
        <div class="form-group">
          <label for="password">密碼</label>
          <input type="password" id="password" name="password" required placeholder="輸入密碼">
        </div>
        <div class="form-actions">
          <button type="submit" class="btn btn-primary btn-large">登入</button>
        </div>
        <% if (!(typeof adminMode !== 'undefined' && adminMode)) { %>
          <p class="auth-footer">
            未有帳號？<a href="/register">立即註冊</a>
          </p>
        <% } %>
      </form>
    </div>
  </main>

  <footer>
    <div class="container">
      <div class="legal-footer" style="background: #f8f9fa; border-radius: 8px; padding: 16px; margin-bottom: 16px; text-align: left; font-size: 13px; line-height: 1.6; color: #495057;">
        <strong>【服務聲明】</strong>
        <ol style="margin: 8px 0 0 20px; padding: 0;">
          <li>本平台僅提供台灣一番賞代購代抽服務，抽選與交易均於台灣進行。</li>
          <li>本站不在香港經營任何抽獎、獎券、投注或賭博活動。</li>
          <li>用戶須年滿18歲，下單即同意本聲明。</li>
          <li>商品以台灣官方內容與機率為準，不設退換。</li>
        </ol>
      </div>
      <p>&copy; <%= new Date().getFullYear() %> Ichiban Kuji Proxy Service</p>
      <p style="margin-top: 8px; opacity: 0.7;">Powered by TMA台灣分部-未來飛翔</p>
    </div>
  </footer>

  <script src="/js/app.js"></script>
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      document.getElementById('loginForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const username = document.getElementById('username').value.trim();
        const password = document.getElementById('password').value;
        
        try {
          const result = await apiRequest('/api/auth/login', {
            method: 'POST',
            body: JSON.stringify({ username, password })
          });
          
          alert('登入成功！');
          const isAdminMode = document.getElementById('adminModeFlag').value === '1';
          if (isAdminMode && !result.user.is_admin) {
            alert('此帳號不是管理員');
            return;
          }
          window.location.href = isAdminMode ? '/admin' : '/my';
        } catch (err) {
          alert(err.message);
        }
      });
    });
  </script>
</body>
</html>
